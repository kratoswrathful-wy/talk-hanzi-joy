# Copy to .env and fill in. Never commit .env with secrets.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Optional: canonical origin for auth redirects (password reset, signup email links).
# Must match an entry in Supabase Authentication → URL Configuration → Redirect URLs
# (e.g. add https://tms.example.com/reset-password when using this origin).
# If unset, the app uses window.location.origin (current tab URL).
# VITE_SUPABASE_AUTH_REDIRECT_ORIGIN=https://tms.example.com
